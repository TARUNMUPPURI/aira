# ──────────────────────────────────────────────────────────────
#  ARIA — .gitignore
# ──────────────────────────────────────────────────────────────

# --- Secrets / environment ---
.env
*.env
.env.*
!.env.example

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so

# --- Distribution / packaging ---
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST
wheels/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- pytest / coverage ---
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov

# --- Type checkers / linters ---
.mypy_cache/
.ruff_cache/
.pytype/

# --- ChromaDB local data (re-seeded at startup) ---
chroma_data/

# --- Kafka / broker state (created by docker compose) ---
kafka-logs/
zookeeper-data/

# --- Streamlit cache ---
.streamlit/

# --- Verification / scratch output files ---
scripts/verify_final_out.txt
*.out.txt

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Docker volumes (if mounted locally) ---
volumes/

# --- Logs ---
*.log
logs/
